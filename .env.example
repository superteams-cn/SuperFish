# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
LLM_REQUEST_TIMEOUT=120

# ===== 图谱构建：分块与抽取（四个参数互相牵制，按下方说明调）=====
# 流程：文档按 DEFAULT_CHUNK_SIZE 切块 → 每块让 LLM 抽取「至多 MAX_TRIPLETS 条三元组」
#       → 结果是 JSON，受 MAX_TOKENS 限制 → 全部抽完再做实体消解(合并别名)。
# 调参经验：
#   • 块越大 → 块越少 → 跨块别名越少；但每块要抽的实体越多。
#   • MAX_TRIPLETS 太小 → 大块漏抽实体；太大 → JSON 超过 MAX_TOKENS 被截断 → 该块 0 结果。
#   • 因此「块大小 / MAX_TRIPLETS / MAX_TOKENS」要配套调：块越大，后两者也要相应调大。
# 推荐：中等块 + 多块 + 实体消解兜底别名（兼顾覆盖率与稳定，不易截断）。
GRAPH_EXTRACT_MAX_TOKENS=16384       # 单块抽取输出 token 上限（块大/三元组多时调大，防 JSON 截断）
GRAPH_EXTRACT_MAX_TRIPLETS=50        # 每块最多抽取的三元组数（块越大可调大，但需 MAX_TOKENS 跟上）
DEFAULT_CHUNK_SIZE=3000             # 文本分块大小（字符），建议 2000~4000
DEFAULT_CHUNK_OVERLAP=200           # 相邻块重叠字符数，约块大小的 5%~10%

# ===== 本体生成：实体/关系类型数量 =====
# 接口 POST /api/graph/ontology/generate 生成的类型数量。同时约束提示词与后处理截断。
ONTOLOGY_ENTITY_TYPES=10            # 实体类型总数（含「个人/组织」2 个兜底，故具体类型=总数-2）；最小 3
ONTOLOGY_EDGE_TYPES_MIN=6          # 关系类型数量下限（仅提示词建议）
ONTOLOGY_EDGE_TYPES_MAX=10          # 关系类型数量上限（同时作为后处理硬截断）

# 知识图谱已改存 Postgres（见 graphs 表 / repositories/graph_repo.py），无需独立图数据库配置。

# ===== Redis 配置（缓存/队列，可选）=====
# 需在 docker-compose 中启动 Redis 服务（已内置）
# 源码部署默认使用 redis://localhost:6379/0
# 完整 docker compose 部署时，SuperFish 容器内应使用 redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ===== Postgres 配置（项目/任务等元数据持久化）=====
# 需在 docker-compose 中启动 Postgres 服务（已内置）
# 完整 docker compose 部署时，SuperFish 容器内应使用 postgres 服务名
DATABASE_URL=postgresql+psycopg://superfish:superfish_pg@localhost:5432/superfish

# ===== S3 兼容对象存储 RustFS 配置（上传文件/提取文本）=====
# 需在 docker-compose 中启动 RustFS 服务（已内置）
# 完整 docker compose 部署时，SuperFish 容器内应使用 http://rustfs:9000
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=superfish
S3_SECRET_KEY=superfish_secret
S3_BUCKET=superfish
S3_REGION=us-east-1

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== 用户体系 / 鉴权（P0-P3）=====
# 上线务必用强随机串覆盖（如 openssl rand -hex 32）；默认值仅供本地开发
JWT_SECRET=dev-insecure-change-me
# 令牌有效期（可选，留空用默认）
# JWT_ACCESS_TTL_MIN=30
# JWT_REFRESH_TTL_DAYS=14
# JWT_RESET_TTL_MIN=30
# JWT_VERIFY_TTL_MIN=1440

# admin 邮箱白名单（逗号分隔），命中者可调用 /admin/* 运维接口
ADMIN_EMAILS=

# 开放注册护栏（可选，留空用默认）
# MAX_PROJECTS_PER_USER=10
# MAX_CONCURRENT_SIMULATIONS=2
# RATE_LIMIT_ENABLED=true

# 拼接邮件链接用的前端地址（重置密码 / 邮箱验证落地页）
WEB_BASE_URL=http://localhost:3000

# ===== 邮件发送（找回密码 / 邮箱验证，正式 SMTP）=====
# 不配置 SMTP_HOST 时走开发桩：邮件内容打印到后端日志（apps/api/logs/<date>.log）
# QQ/163/企业邮箱常用 465(SSL)；Gmail/SendGrid 常用 587(STARTTLS)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
# 注意：多数邮箱用「授权码/应用专用密码」而非登录密码
SMTP_PASSWORD=
# 直连 SSL 还是 STARTTLS：留空按端口自动判定(465→SSL)，也可显式 true/false
# SMTP_USE_SSL=
# SMTP_USE_TLS=true
EMAIL_FROM=SuperFish <no-reply@superfish.local>
