{
  "name": "superfish",
  "version": "0.1.0",
  "private": true,
  "description": "SuperFish - 简洁通用的群体智能引擎，预测万物",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @superfish/web dev",
    "dev:api": "pnpm --filter @superfish/api dev",
    "dev:worker": "pnpm --filter @superfish/api worker",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"apps/web/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"apps/web/**/*.{ts,tsx}\"",
    "setup": "pnpm install && pnpm setup:api",
    "setup:api": "pnpm --filter @superfish/api setup",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "license": "AGPL-3.0"
}
